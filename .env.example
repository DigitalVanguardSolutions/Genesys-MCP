# Genesys MCP — example environment file. Copy to `.env` and fill in.

# ── Transport ──────────────────────────────────────────────────────
# Transport selection: stdio (default) | http
MCP_TRANSPORT=stdio

# HTTP transport bind address (only used when MCP_TRANSPORT=http)
MCP_HOST=127.0.0.1
MCP_PORT=8000

# ── Logging ────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Writes (read-only by default; opt-in for low-blast-radius writes) ──
# See ADR-009. Set to true to enable presence.set / add_note / set_wrapup_code.
GENESYS_MCP_ENABLE_WRITES=false

# ── Genesys Cloud OAuth (Client Credentials only in the public package) ──
# See ADR-005 / ADR-006. M1 ships the framework; M2 wires these to the SDK.
GENESYS_REGION=mypurecloud.com
GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=

# ── OpenTelemetry (optional) ───────────────────────────────────────
# Default exporter is the OTel console exporter. Set this to enable OTLP
# in addition to console output.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=genesys-mcp
